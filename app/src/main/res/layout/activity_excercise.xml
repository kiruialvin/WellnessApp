<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#F80606"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Excercise">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Excercise"
        android:textSize="30sp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:textColor="#2FFF02"
        android:fontFamily="times"

        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:layout_margin="60dp"
        android:scaleType="centerCrop"
        android:src="@drawable/exer" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="a planned, structured, and repetitive form of physical activity aimed at improving or maintaining physical fitness"
        android:textColor="#000000"
        android:fontFamily="times"
        android:textSize="30sp"

        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="30dp"
        android:backgroundTint="#41C6FF"
        android:text="View Exercises"
        android:textSize="20sp"
        android:fontFamily="sans-serif-condensed-light"/>




</LinearLayout>