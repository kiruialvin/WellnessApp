<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#F80606"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Motivation">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily Motivation"
        android:textSize="30sp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:textColor="#2FFF02"
        android:fontFamily="times"

        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:src="@drawable/mo"
        android:layout_margin="50dp"
        android:scaleType="centerCrop"

        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="the consistent, inner drive that fuels ongoing progress, resilience, and goal pursuit, rather than a temporary boost. It acts as a mental habit enabling you to overcome resistance"
        android:textColor="#000000"
        android:fontFamily="sans-serif-condensed-medium"
        android:textSize="20sp"
        android:textAlignment="center"
        />

    <Button
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="30dp"
    android:backgroundTint="#41C6FF"
    android:text="View Motivation"
    android:textSize="30sp"
    android:fontFamily="sans-serif-condensed-light"
    android:textAlignment="center"
    />


</LinearLayout>